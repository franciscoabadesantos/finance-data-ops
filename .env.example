# Required when publish is enabled
DATA_OPS_DATABASE_URL=postgresql://finance_ops:__PASSWORD__@127.0.0.1:6432/finance

# Required for scheduled runs unless --symbols is passed explicitly
DATA_OPS_SYMBOLS=SPY,QQQ,IWM,TLT,GLD,EFA

# Optional region-specific symbol universes for region-parameterized runs
DATA_OPS_SYMBOLS_US=
DATA_OPS_SYMBOLS_EU=
DATA_OPS_SYMBOLS_APAC=

# Optional runtime controls
DATA_OPS_LOOKBACK_DAYS=400
DATA_OPS_MAX_ATTEMPTS=3
DATA_OPS_SYMBOL_BATCH_SIZE=100
DATA_OPS_CACHE_ROOT=./data_cache

# Optional alert sink for critical failures (JSON POST webhook)
DATA_OPS_ALERT_WEBHOOK_URL=
